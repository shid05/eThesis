<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("partials/head") %>
  <title>Edit Rating - LNC Research Archives</title>
  <script src="/socket.io/socket.io.js"></script>
  <script src="/public/js/notifications.js"></script>
  <script>
    async function loadExistingRating() {
      try {
        const id = location.pathname.split('/').pop();
        const res = await fetch(`/student-ratings/api/edit/${id}`);
        
        if (!res.ok) {
          const errorData = await res.json().catch(() => ({}));
          const errorMessage = errorData.error || 'Rating not found';
          document.getElementById('content').innerHTML = `
            <div class="card center flex-col gap-20 min-height-40vh">
              <h2 class="text-danger">Error</h2>
              <p class="muted">${errorMessage}</p>
              <a href="/thesis" class="btn">Back to Thesis</a>
            </div>
          `;
          return;
        }
        
        const rating = await res.json();
        
        // Update thesis information
        document.getElementById('thesisTitle').textContent = rating.thesisId.title;
        document.getElementById('thesisAuthor').textContent = rating.thesisId.author?.name || 'Unknown';
        
        // Pre-fill the form with existing rating
        document.getElementById('comment').value = rating.comment;
        document.getElementById('rating').value = rating.rating;
        updateStars(rating.rating);
        
        // Update form action
        document.getElementById('ratingForm').action = `/student-ratings/edit/${id}`;
        
        // Update page title
        document.title = `Edit Rating: ${rating.thesisId.title} - LNC Research Archives`;
        
      } catch (error) {
        console.error('Error loading existing rating:', error);
        document.getElementById('content').innerHTML = `
          <div class="card center flex-col gap-20 min-height-40vh">
            <h2 class="text-danger">Error</h2>
            <p class="muted">Failed to load rating details</p>
            <a href="/thesis" class="btn">Back to Thesis</a>
          </div>
        `;
      }
    }
    
    function validate() {
      const comment = document.getElementById('comment').value.trim();
      const rating = document.getElementById('rating').value;
      
      // Clear previous error messages
      clearErrors();
      
      let hasErrors = false;
      
      if (!comment) {
        showError('comment', 'Comment is required');
        hasErrors = true;
      } else if (comment.length < 10) {
        showError('comment', 'Comment must be at least 10 characters long');
        hasErrors = true;
      } else if (comment.length > 1000) {
        showError('comment', 'Comment cannot exceed 1000 characters');
        hasErrors = true;
      }
      
      if (!rating) {
        showError('rating', 'Please select a rating');
        hasErrors = true;
      }
      
      if (hasErrors) {
        return false;
      }
      
      return true;
    }
    
    function showError(fieldId, message) {
      const field = document.getElementById(fieldId);
      const errorDiv = document.createElement('div');
      errorDiv.className = 'error-message';
      errorDiv.style.color = '#ff6b6b';
      errorDiv.style.fontSize = '0.875rem';
      errorDiv.style.marginTop = '4px';
      errorDiv.textContent = message;
      
      field.style.borderColor = '#ff6b6b';
      field.parentNode.appendChild(errorDiv);
    }
    
    function clearErrors() {
      const errorMessages = document.querySelectorAll('.error-message');
      errorMessages.forEach(msg => msg.remove());
      
      const inputs = document.querySelectorAll('input, textarea, select');
      inputs.forEach(input => {
        input.style.borderColor = '';
      });
    }
    
    function updateStars(rating) {
      const stars = document.querySelectorAll('.star');
      stars.forEach((star, index) => {
        if (index < rating) {
          star.classList.add('active');
        } else {
          star.classList.remove('active');
        }
      });
      document.getElementById('rating').value = rating;
    }
    
    document.addEventListener('DOMContentLoaded', async () => {
      await loadExistingRating();
      
      // Set current user for real-time features
      try {
        const userResponse = await fetch('/session-info');
        const userData = await userResponse.json();
        if (userData.user) {
          setCurrentUser(userData.user);
        }
      } catch (error) {
        console.error('Error setting user:', error);
      }
    });
  </script>
  <style>
    .rating-stars {
      display: flex;
      gap: 5px;
      margin: 10px 0;
    }
    
    .star {
      font-size: 2rem;
      color: #ddd;
      cursor: pointer;
      transition: color 0.2s;
    }
    
    .star:hover,
    .star.active {
      color: #fbbf24;
    }
    
    .thesis-info {
      background: var(--panel);
      padding: 20px;
      border-radius: 8px;
      margin-bottom: 20px;
    }
  </style>
</head>
<body>
  <div class="bg-bokeh"></div>
  <%- include('partials/navbar') %>
  
  <main class="container" id="content">
    <div class="card">
      <h2>✏️ Edit Your Rating</h2>
      
      <div class="thesis-info">
        <h3 id="thesisTitle">Loading...</h3>
        <p>Author: <strong id="thesisAuthor">Loading...</strong></p>
      </div>
      
      <form id="ratingForm" method="POST" class="form-card" onsubmit="return validate()">
        <div class="form-group">
          <label for="rating">Your Rating</label>
          <div class="rating-stars">
            <span class="star" onclick="updateStars(1)">★</span>
            <span class="star" onclick="updateStars(2)">★</span>
            <span class="star" onclick="updateStars(3)">★</span>
            <span class="star" onclick="updateStars(4)">★</span>
            <span class="star" onclick="updateStars(5)">★</span>
          </div>
          <input type="hidden" id="rating" name="rating" required />
          <small class="muted">Click the stars to update your rating from 1 to 5</small>
        </div>
        
        <div class="form-group">
          <label for="comment">Your Comment</label>
          <textarea 
            id="comment" 
            name="comment" 
            rows="5" 
            required 
            placeholder="Update your thoughts about this thesis..."
            minlength="10"
            maxlength="1000"
          ></textarea>
          <small class="muted">Minimum 10 characters, maximum 1000 characters</small>
        </div>
        
        <div class="card warning">
          <h4>✏️ Editing Your Rating</h4>
          <p>You are updating your existing rating for this thesis. Your updated rating and comment will replace your previous submission.</p>
        </div>
        
        <div class="form-actions">
          <button type="submit" class="btn primary">✏️ Update Rating</button>
          <a href="javascript:history.back()" class="btn ghost">Cancel</a>
        </div>
      </form>
    </div>
  </main>
  
  <%- include('partials/footer') %>
</body>
</html>
