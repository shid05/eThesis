<nav class="navbar" id="siteNavbar">
  <a href="/" class="brand" aria-label="LNC Research Archives - Home">LNC Research Archives</a>

  <button
    type="button"
    class="nav-toggle"
    id="navToggle"
    aria-label="Toggle navigation menu"
    aria-controls="navLinks"
    aria-expanded="false"
  >
    <span class="nav-toggle-bar"></span>
    <span class="nav-toggle-bar"></span>
    <span class="nav-toggle-bar"></span>
  </button>

  <div class="links" id="navLinks">
    <a href="/">Home</a>
    <a href="/thesis">Thesis</a>
    <% if (typeof currentUser !== 'undefined' && currentUser) { %>
      <% if (currentUser.role === 'Student') { %>
        <a href="/thesis/mine">My Thesis</a>
        <a href="/thesis/upload" class="btn primary sm">📤 Upload Thesis</a>
      <% } else if (currentUser.role === 'Teacher') { %>
        <a href="/thesis/reviewer/pending" class="btn accent sm">📝 Review Queue</a>
      <% } else if (currentUser.role === 'Admin') { %>
        <a href="/thesis/admin/pending" class="nav-link-with-badge" data-badge-link="pendingTheses">
          ⏳ Pending Thesis
          <span class="nav-badge" id="badgePendingTheses" data-count="0" aria-live="polite" aria-label="0 new pending thesis" hidden>0</span>
        </a>
        <a href="/admin/account-requests" class="nav-link-with-badge" data-badge-link="pendingRequests">
          👤 Requests
          <span class="nav-badge" id="badgeAccountRequests" data-count="0" aria-live="polite" aria-label="0 new pending account requests" hidden>0</span>
        </a>
        <a href="/admin/users">👥 Users</a>
        <a href="/admin/reports">📊 Reports</a>
        <a href="/admin/dashboard" class="btn warning sm">⚙️ Dashboard</a>
      <% } %>
      <a href="/profile">Profile</a>
      <span id="authLinks">
        <a href="/logout" class="btn ghost sm">Logout</a>
      </span>
    <% } else { %>
      <span id="authLinks">
        <a href="/login" class="btn ghost sm">Login</a>
        <a href="/request-account" class="btn sm">Request Account</a>
      </span>
    <% } %>
  </div>
</nav>

<div class="nav-backdrop" id="navBackdrop" aria-hidden="true"></div>

<%
/*
  Notification Bell
  -----------------
  Persistent dropdown that records every real-time notification the user
  receives (server-pushed via Socket.IO). Floats just below the navbar at
  the top-right. Visible only when a user is logged in. Storage is keyed
  by the user id (notifBellHistory.<userId> in localStorage) so different
  users on the same browser don't see each other's history.
*/
%>
<% if (typeof currentUser !== 'undefined' && currentUser) { %>
<div id="notifBellWrapper" class="notif-bell-wrapper">
  <button type="button"
          id="notifBellBtn"
          class="notif-bell"
          aria-label="Notifications — dismiss the banner when it is showing, otherwise open or close the list"
          aria-haspopup="true"
          aria-expanded="false"
          aria-controls="notifPanel">
    <svg viewBox="0 0 24 24" width="18" height="18" fill="none"
         stroke="currentColor" stroke-width="2"
         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/>
      <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
    </svg>
    <span id="notifBellBadge" class="notif-bell-badge" aria-live="polite" hidden>0</span>
  </button>

  <div id="notifPanel"
       class="notif-panel"
       role="dialog"
       aria-labelledby="notifPanelHeading"
       hidden>
    <div class="notif-panel-header">
      <h4 id="notifPanelHeading">Notifications</h4>
      <div class="notif-panel-actions">
        <button type="button" id="notifClearAllBtn" class="notif-clear-btn">Clear all</button>
      </div>
    </div>
    <ul id="notifPanelList" class="notif-panel-list" aria-live="polite"></ul>
    <div id="notifPanelEmpty" class="notif-panel-empty">
      <div class="notif-empty-icon" aria-hidden="true">🔕</div>
      <div>You have no notifications.</div>
    </div>
  </div>
</div>

<style>
  /* Floating bell wrapper — fixed so it stays visible while scrolling */
  .notif-bell-wrapper {
    position: fixed;
    /* Clear the sticky navbar (height varies by breakpoint); safe-area for notched phones */
    top: calc(92px + env(safe-area-inset-top, 0px));
    right: calc(20px + env(safe-area-inset-right, 0px));
    z-index: 10200;    /* above .notification toast so the bell is never covered */
    pointer-events: auto;
  }

  /* The bell button itself — circular control */
  .notif-bell {
    box-sizing: border-box;
    width: 44px;
    height: 44px;
    min-width: 44px;
    min-height: 44px;
    padding: 0;
    border-radius: 50%;
    border: 1px solid var(--border, rgba(255, 255, 255, 0.12));
    background: var(--panel, #1e293b);
    color: var(--text, #f1f5f9);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    cursor: pointer;
    position: relative;
    overflow: visible;
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.28);
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;   /* kill 300ms tap delay on Android/iOS */
    transition: transform 150ms ease, background-color 150ms ease;
  }
  .notif-bell:hover {
    transform: scale(1.06);
    background: var(--panel-hover, #283548);
  }
  .notif-bell:focus-visible {
    outline: 2px solid var(--primary, #3b82f6);
    outline-offset: 2px;
  }
  /* Global `button::before` (shimmer) sits on top and can break taps on some engines */
  .notif-bell::before {
    content: none !important;
    display: none !important;
  }

  .notif-bell svg {
    display: block;
    flex-shrink: 0;
    pointer-events: none;
  }
  .notif-bell.has-unread svg {
    /* gentle wiggle when there are unread notifications, runs once */
    animation: notifBellShake 0.6s ease-in-out;
  }
  @keyframes notifBellShake {
    0%, 100% { transform: rotate(0); }
    20% { transform: rotate(-12deg); }
    40% { transform: rotate(10deg); }
    60% { transform: rotate(-6deg); }
    80% { transform: rotate(4deg); }
  }

  /* Red unread-count badge */
  .notif-bell-badge {
    position: absolute;
    top: -4px;
    right: -4px;
    min-width: 18px;
    height: 18px;
    padding: 0 5px;
    border-radius: 9px;
    background: #dc2626;
    color: #ffffff;
    font-size: 10px;
    font-weight: 700;
    line-height: 18px;
    text-align: center;
    border: 2px solid var(--panel, #1e293b);
    box-shadow: 0 2px 6px rgba(220, 38, 38, 0.5);
  }

  /* Dropdown panel */
  .notif-panel {
    position: absolute;
    top: 52px;          /* below the circular bell */
    right: 0;
    width: 340px;
    max-width: calc(100vw - 40px);
    background: var(--panel, #1e293b);
    border: 1px solid var(--border, rgba(255, 255, 255, 0.1));
    border-radius: 12px;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.4);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    /* Smooth toggle transition */
    opacity: 0;
    transform: translateY(-8px) scale(0.96);
    transition: opacity 0.2s ease, transform 0.2s ease;
    pointer-events: none;
  }
  .notif-panel.is-open {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .notif-panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--border, rgba(255, 255, 255, 0.08));
    position: relative;
    z-index: 2;
  }
  .notif-panel-header h4 { margin: 0; font-size: 14px; color: var(--text, #f1f5f9); }

  .notif-panel-actions {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .notif-clear-btn {
    background: none;
    border: none;
    color: var(--primary, #3b82f6);
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
    padding: 4px 8px;
    border-radius: 6px;
    transition: background-color 150ms ease;
  }
  .notif-clear-btn:hover { background: rgba(59, 130, 246, 0.12); }
  .notif-clear-btn:disabled { color: var(--muted, #94a3b8); cursor: not-allowed; background: transparent; }

  /* Scrollable list — 'declared height' the user mentioned */
  .notif-panel-list {
    list-style: none;
    margin: 0;
    padding: 0;
    max-height: 380px;
    overflow-y: auto;
    overscroll-behavior: contain;     /* don't scroll the page when list edge is reached */
  }

  .notif-panel-list::-webkit-scrollbar { width: 6px; }
  .notif-panel-list::-webkit-scrollbar-thumb {
    background: rgba(148, 163, 184, 0.3);
    border-radius: 3px;
  }
  .notif-panel-list::-webkit-scrollbar-thumb:hover {
    background: rgba(148, 163, 184, 0.5);
  }

  .notif-item {
    padding: 12px 16px;
    border-bottom: 1px solid var(--border, rgba(255, 255, 255, 0.05));
    display: grid;
    grid-template-columns: 4px 1fr;
    gap: 10px;
    align-items: start;
  }
  .notif-item:last-child { border-bottom: none; }
  .notif-item.unread { background: rgba(59, 130, 246, 0.06); }

  .notif-item-accent {
    width: 4px;
    align-self: stretch;
    border-radius: 2px;
    background: #2563eb;
  }
  .notif-item-accent.success { background: #16a34a; }
  .notif-item-accent.error   { background: #dc2626; }
  .notif-item-accent.warning { background: #d97706; }
  .notif-item-accent.info    { background: #2563eb; }

  .notif-item-title {
    margin: 0 0 2px 0;
    font-size: 13px;
    font-weight: 600;
    color: var(--text, #f1f5f9);
  }
  .notif-item-message {
    margin: 0;
    font-size: 12px;
    line-height: 1.45;
    color: var(--muted, #94a3b8);
    word-break: break-word;
  }
  .notif-item-time {
    font-size: 10px;
    color: var(--muted, #64748b);
    margin-top: 4px;
  }

  .notif-panel-empty {
    padding: 32px 16px;
    text-align: center;
    color: var(--muted, #94a3b8);
    font-size: 13px;
  }
  .notif-empty-icon { font-size: 32px; margin-bottom: 8px; }

  /* Mobile: stretch the panel to nearly full width and tighten the offset */
  @media (max-width: 1024px) {
    .notif-bell-wrapper {
      top: calc(76px + env(safe-area-inset-top, 0px));
      right: calc(16px + env(safe-area-inset-right, 0px));
    }
    .notif-panel {
      /* Solid background on tablets too */
      background: var(--panel-solid, #151c2a);
    }
  }

  @media (max-width: 600px) {
    .notif-bell-wrapper {
      top: calc(68px + env(safe-area-inset-top, 0px));
      right: calc(12px + env(safe-area-inset-right, 0px));
    }
    .notif-bell {
      width: 40px;
      height: 40px;
      min-width: 40px;
      min-height: 40px;
    }
    .notif-bell svg {
      width: 18px;
      height: 18px;
    }
    .notif-panel {
      /* Full-width panel anchored to screen edges */
      position: fixed;
      top: calc(68px + env(safe-area-inset-top, 0px) + 48px);
      right: 12px;
      left: 12px;
      width: auto;
      max-width: none;
      background: var(--panel-solid, #151c2a);
    }
    .notif-panel-list { max-height: 60vh; }
  }

  /* When the nav drawer is open, hide the bell so it doesn't float on top */
  body.nav-open .notif-bell-wrapper {
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s ease;
  }
</style>
<% } %>

<script>
  (function () {
    var toggle = document.getElementById('navToggle');
    var links = document.getElementById('navLinks');
    var backdrop = document.getElementById('navBackdrop');
    var navbar = document.getElementById('siteNavbar');
    if (!toggle || !links || !navbar) return;

    function setOpen(open) {
      navbar.classList.toggle('is-open', open);
      links.classList.toggle('is-open', open);
      toggle.classList.toggle('is-open', open);
      if (backdrop) backdrop.classList.toggle('is-open', open);
      document.body.classList.toggle('nav-open', open);
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      // Mutual exclusion: close notification panel when hamburger opens
      if (open && window.notifBell) window.notifBell.togglePanel(false);
    }

    // Expose globally so notifications.js can close the hamburger when the bell opens
    window.navSetOpen = setOpen;

    toggle.addEventListener('click', function () {
      setOpen(!navbar.classList.contains('is-open'));
    });

    if (backdrop) {
      backdrop.addEventListener('click', function () { setOpen(false); });
    }

    // Close drawer when a link is tapped (mobile UX)
    links.querySelectorAll('a').forEach(function (a) {
      a.addEventListener('click', function () {
        if (window.matchMedia('(max-width: 1024px)').matches) setOpen(false);
      });
    });

    // Close on Escape
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') setOpen(false);
    });

    // Auto-close when resizing back to desktop width
    var mq = window.matchMedia('(min-width: 1025px)');
    var mqHandler = function (e) { if (e.matches) setOpen(false); };
    if (mq.addEventListener) mq.addEventListener('change', mqHandler);
    else if (mq.addListener) mq.addListener(mqHandler);
  })();
</script>

<% if (typeof currentUser !== 'undefined' && currentUser && currentUser.role === 'Admin') { %>
<script>
  /**
   * Admin notification badges (top-corner notification dots)
   *
   * Behaviour:
   *   - Server pushes the LIVE pending count via Socket.IO.
   *   - Client tracks a "seen" baseline per badge in localStorage.
   *   - Badge is visible only when liveCount > seenCount (i.e. there are
   *     unseen items). Clicking the link "acknowledges" the current count
   *     (seenCount := liveCount) and the badge disappears immediately.
   *   - When NEW items arrive later, liveCount > seenCount again, so the
   *     badge reappears with the new total.
   *   - Across tabs: the storage event keeps every open admin tab in sync.
   */
  (function () {
    var TARGETS = {
      pendingTheses: {
        el: 'badgePendingTheses',
        link: '[data-badge-link="pendingTheses"]',
        storageKey: 'navBadgeSeen.pendingTheses',
        label: function (n) { return n + ' new pending thesis'; }
      },
      pendingRequests: {
        el: 'badgeAccountRequests',
        link: '[data-badge-link="pendingRequests"]',
        storageKey: 'navBadgeSeen.pendingRequests',
        label: function (n) { return n + ' new pending account ' + (n === 1 ? 'request' : 'requests'); }
      }
    };

    // Live counts as last reported by the server.
    var live = { pendingTheses: 0, pendingRequests: 0 };

    function getSeen(key) {
      try {
        var raw = localStorage.getItem(TARGETS[key].storageKey);
        var v = parseInt(raw == null ? '0' : raw, 10);
        return isNaN(v) || v < 0 ? 0 : v;
      } catch (e) { return 0; }
    }

    function setSeen(key, val) {
      try { localStorage.setItem(TARGETS[key].storageKey, String(val)); }
      catch (e) { /* private mode or quota exceeded — ignore */ }
    }

    function renderOne(key) {
      var conf = TARGETS[key];
      var badge = document.getElementById(conf.el);
      if (!badge) return;

      var current = live[key];
      var seen = getSeen(key);

      // If the live count drops below the baseline (e.g. another admin
      // processed items), lower the baseline so that future increments
      // still cause the badge to surface again.
      if (current < seen) {
        seen = current;
        setSeen(key, seen);
      }

      var prev = parseInt(badge.dataset.count || '0', 10);
      var shouldShow = current > seen && current > 0;

      badge.textContent = current > 99 ? '99+' : String(current);
      badge.dataset.count = String(current);
      badge.setAttribute('aria-label', conf.label(current));

      if (shouldShow) {
        badge.hidden = false;
        if (current !== prev) {
          // replay the one-shot bump animation on count change
          badge.classList.remove('is-bumping');
          void badge.offsetWidth;
          badge.classList.add('is-bumping');
        }
      } else {
        badge.hidden = true;
        badge.classList.remove('is-bumping');
      }
    }

    function applyBadgeCounts(counts) {
      if (!counts || typeof counts !== 'object') return;
      Object.keys(TARGETS).forEach(function (key) {
        if (counts[key] !== undefined && counts[key] !== null) {
          live[key] = Math.max(0, parseInt(counts[key], 10) || 0);
        }
        renderOne(key);
      });
    }

    function acknowledge(key) {
      // Mark the current live count as "seen" — badge will hide on next render.
      setSeen(key, live[key]);
      renderOne(key);
    }

    function attachAckHandlers() {
      Object.keys(TARGETS).forEach(function (key) {
        var conf = TARGETS[key];
        var link = document.querySelector(conf.link);
        if (!link) return;
        link.addEventListener('click', function () { acknowledge(key); });
        // Also acknowledge if the user is already on the section's page
        // (so opening a new browser tab on /admin/account-requests etc.
        // immediately clears the badge).
        var path = link.getAttribute('href');
        if (path && location.pathname.indexOf(path) === 0) {
          // defer until after the initial fetch resolves
          setTimeout(function () { acknowledge(key); }, 0);
        }
      });
    }

    // Cross-tab sync: another tab acknowledged → re-render here as well.
    window.addEventListener('storage', function (e) {
      if (!e.key) return;
      Object.keys(TARGETS).forEach(function (key) {
        if (e.key === TARGETS[key].storageKey) renderOne(key);
      });
    });

    // Expose globally so notifications.js can drive updates over Socket.IO.
    window.applyBadgeCounts = applyBadgeCounts;

    function fetchInitial() {
      fetch('/api/admin/badge-counts', {
        headers: { 'Accept': 'application/json' },
        credentials: 'same-origin'
      })
        .then(function (r) { return r.ok ? r.json() : null; })
        .then(function (counts) { if (counts) applyBadgeCounts(counts); })
        .catch(function () { /* fail silently — socket will catch up */ });
    }

    function init() {
      attachAckHandlers();
      fetchInitial();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
<% } %>
