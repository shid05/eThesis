<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("partials/head") %>
  <title><%= thesis ? thesis.title + ' - LNC Research Archives' : 'Thesis Detail - LNC Research Archives' %></title>
  <script src="/socket.io/socket.io.js"></script>
  <script src="/public/js/notifications.js"></script>
</head>
<body>
  <div class="bg-bokeh"></div>
  <%- include('partials/navbar') %>
  
  <main class="container" id="content">
    <!-- Thesis Bento Layout -->
    <div class="thesis-bento-layout">
      <!-- Left Column: Details & Abstract -->
      <div class="bento-main">
        <div class="bento-info">
          <h1 id="title" class="thesis-title"><%= thesis ? thesis.title : 'Loading...' %></h1>
          <div class="thesis-meta" style="display: flex; flex-wrap: wrap; gap: 15px; margin-bottom: 20px;">
            <div class="meta-item">
              <span class="meta-icon">👤</span>
              <span class="meta-label">Uploader:</span>
              <strong id="author" class="meta-value"><%= thesis ? (thesis.author?.name || 'Unknown') : 'Loading...' %></strong>
            </div>
            <div class="meta-item">
              <span class="meta-icon">👥</span>
              <span class="meta-label">Authors:</span>
              <strong id="authorsName" class="meta-value"><%= thesis ? (thesis.authorsName || 'N/A') : 'Loading...' %></strong>
            </div>
            <div class="meta-item">
              <span class="meta-icon">👨‍🏫</span>
              <span class="meta-label">Adviser:</span>
              <strong id="adviser" class="meta-value"><%= thesis ? (thesis.adviser || 'N/A') : 'Loading...' %></strong>
            </div>
            <div class="meta-item">
              <span class="meta-icon">🎓</span>
              <span class="meta-label">Course:</span>
              <strong id="course" class="meta-value"><%= thesis ? (thesis.course || 'N/A') : 'Loading...' %></strong>
            </div>
            <div class="meta-item">
              <span class="meta-icon">📑</span>
              <span class="meta-label">Category:</span>
              <strong id="category" class="meta-value badge outline"><%= thesis ? (thesis.category || 'N/A') : 'Loading...' %></strong>
            </div>
            <div class="meta-item">
              <span class="meta-icon">📅</span>
              <span class="meta-label">Status:</span>
              <span id="status" class="meta-value badge <%= thesis ? (thesis.status || 'Unknown').toLowerCase() : 'loading' %>"><%= thesis ? (thesis.status || 'Unknown') : 'Loading...' %></span>
            </div>
            <div class="meta-item">
              <span class="meta-icon">🎓</span>
              <span class="meta-label">Capstone Year:</span>
              <strong id="yearPublished" class="meta-value"><%= thesis ? (thesis.yearPublished || 'Not specified') : 'Loading...' %></strong>
            </div>
            <div class="meta-item">
              <span class="meta-icon">🕐</span>
              <span class="meta-label">Uploaded:</span>
              <strong id="uploadDate" class="meta-value"><%= thesis ? new Date(thesis.createdAt).toLocaleDateString() : 'Loading...' %></strong>
            </div>
          </div>
          
          <h3 class="margin-top-20">📋 Abstract</h3>
          <p id="abstract" class="abstract-text enhanced"><%= thesis ? (thesis.abstract || 'No abstract available') : 'Loading...' %></p>
        </div>
      </div>
      
      <!-- Right Column: Actions & Download -->
      <div class="bento-sidebar">
        <!-- Management Card -->
        <div class="content-card management-card" style="height: 100%;">
          <!-- Action Buttons -->
          <div id="actionContainer" style="display: none; margin-bottom: 24px; padding-bottom: 24px; border-bottom: 1px solid rgba(255,255,255,0.05);">
            <div id="actionBar" class="action-buttons vertical"></div>
          </div>
          
          <!-- Request File Section -->
          <div class="download-container center flex-col" style="flex: 1; justify-content: center;">
            <div class="download-icon" style="font-size: 3rem; margin-bottom: 16px; filter: drop-shadow(0 4px 8px rgba(0,0,0,0.3));">📬</div>
            <h3 style="margin-bottom: 4px;">Request Thesis File</h3>
            <p class="muted text-sm text-center" style="margin-bottom: 20px;">Submit a request to receive the full PDF via email</p>
            <div id="requestFileArea" style="display:flex; flex-direction:column; align-items:center;">
              <a href="/login" class="btn lg ghost" id="requestFileFallback">
                <span class="btn-icon">&#x1F512;</span> Login to Request
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
    
  </main>
  
  <%- include('partials/footer') %>
  
  <script>
    async function load(){
      try {
        const id = location.pathname.split('/').pop();
        if (!id || id.length !== 24) throw new Error('Invalid thesis ID format');
        
        const res = await fetch(`/thesis/api/${id}`);
        if (!res.ok) {
          const errorText = await res.text().catch(() => 'Unknown error');
          showError(`Error ${res.status}: ${errorText}`);
          return;
        }
        
        const data = await res.json();
        if (!data || !data.thesis) throw new Error('No thesis data received');
        
        const { thesis, userRole, isAuthor, canRequest, existingRequest } = data;
        
        updateThesisInfo(thesis, userRole);
        setupUserActions(thesis, userRole);
        setupRequestButton(thesis, userRole, isAuthor, canRequest, existingRequest);
        
      } catch (error) {
        console.error('Critical error in load function:', error);
        showError(`Failed to load thesis: ${error.message}`);
      }
    }
    
    function updateThesisInfo(thesis, userRole) {
      try {
        document.getElementById('title').textContent = thesis.title || 'Unknown Title';
        document.getElementById('author').textContent = thesis.author?.name || 'Unknown Author';
        if (document.getElementById('authorsName')) document.getElementById('authorsName').textContent = thesis.authorsName || 'N/A';
        if (document.getElementById('adviser')) document.getElementById('adviser').textContent = thesis.adviser || 'N/A';
        if (document.getElementById('course')) document.getElementById('course').textContent = thesis.course || 'N/A';
        if (document.getElementById('category')) document.getElementById('category').textContent = thesis.category || 'N/A';
        if (document.getElementById('yearPublished')) document.getElementById('yearPublished').textContent = thesis.yearPublished || 'Not specified';
        if (document.getElementById('uploadDate')) document.getElementById('uploadDate').textContent = thesis.createdAt ? new Date(thesis.createdAt).toLocaleDateString() : 'N/A';
        document.getElementById('abstract').textContent = thesis.abstract || 'No abstract available';
        
        const statusElement = document.getElementById('status');
        if (statusElement) {
          statusElement.textContent = thesis.status || 'Unknown';
          statusElement.className = 'meta-value badge';
          
          if (thesis.status === 'Approved') statusElement.classList.add('success');
          else if (thesis.status === 'Pending') statusElement.classList.add('warning');
          else if (thesis.status === 'Rejected') statusElement.classList.add('danger');
        }
        
        // Handle rejection reason display
        const existingRejectNote = document.getElementById('rejectNoteContainer');
        if (existingRejectNote) existingRejectNote.remove();
        
        if (thesis.status === 'Rejected' && thesis.rejectionReason) {
            const bentoInfo = document.querySelector('.bento-info');
            if (bentoInfo) {
                const rejectDiv = document.createElement('div');
                rejectDiv.id = 'rejectNoteContainer';
                rejectDiv.className = 'error-box';
                rejectDiv.style.marginTop = '15px';
                rejectDiv.style.marginBottom = '20px';
                rejectDiv.style.padding = '15px';
                rejectDiv.style.borderRadius = '8px';
                rejectDiv.style.background = 'rgba(239, 68, 68, 0.1)';
                rejectDiv.style.border = '1px solid rgba(239, 68, 68, 0.3)';
                rejectDiv.style.color = '#ef4444';
                rejectDiv.innerHTML = `<h4 style="margin:0 0 8px 0;">❌ Rejection Note:</h4><p style="margin:0;">${thesis.rejectionReason}</p>`;
                
                // Insert after thesis-meta
                const metaDiv = document.querySelector('.thesis-meta');
                if (metaDiv) {
                    metaDiv.after(rejectDiv);
                } else {
                    bentoInfo.appendChild(rejectDiv);
                }
            }
        }
        
        document.title = `${thesis.title} - LNC Research Archives`;
      } catch (error) {
        console.error('Error updating thesis info:', error);
      }
    }
    
    function setupUserActions(thesis, userRole) {
      try {
        const actionBar = document.getElementById('actionBar');
        const actionContainer = document.getElementById('actionContainer');
        if (actionBar) actionBar.innerHTML = '';
        
        let hasActions = false;
        
        // Admin/Adviser actions for pending theses
        const currentUserName = "<%- currentUser && currentUser.name ? currentUser.name.toLowerCase().replace(/['\"\\\\]/g, '\\\\$&') : '' %>";
        const thesisAdviser = thesis.adviser ? thesis.adviser.toLowerCase() : '';
        const isAdviser = userRole === 'Teacher' && thesisAdviser !== '' && thesisAdviser === currentUserName;
        
        if ((userRole === 'Admin' || isAdviser) && thesis.status === 'Pending') {
          const approveForm = document.createElement('form');
          approveForm.method = 'POST';
          approveForm.action = `/thesis/${thesis._id}/approve`;
          approveForm.style.width = '100%';
          approveForm.innerHTML = `
            <button type="submit" class="btn lg success responsive" style="width: 100%; justify-content: center; text-align: center;"><span class="btn-icon">✅</span> Approve Thesis</button>
          `;
          actionBar.appendChild(approveForm);
          
          const rejectBtn = document.createElement('a');
          rejectBtn.href = '#';
          rejectBtn.className = 'btn lg danger responsive';
          rejectBtn.style.justifyContent = 'center';
          rejectBtn.style.textAlign = 'center';
          rejectBtn.style.width = '100%';
          rejectBtn.onclick = (e) => { e.preventDefault(); showRejectModal(thesis._id, thesis.title); };
          rejectBtn.innerHTML = '<span class="btn-icon">❌</span> Reject Thesis';
          actionBar.appendChild(rejectBtn);
          hasActions = true;
        }
        
        // Admin/Adviser actions for approved theses (revoke)
        if ((userRole === 'Admin' || isAdviser) && thesis.status === 'Approved') {
          const revokeBtn = document.createElement('a');
          revokeBtn.href = '#';
          revokeBtn.className = 'btn lg warning responsive';
          revokeBtn.style.justifyContent = 'center';
          revokeBtn.style.textAlign = 'center';
          revokeBtn.style.width = '100%';
          revokeBtn.onclick = (e) => { e.preventDefault(); showRevokeModal(thesis._id, thesis.title); };
          revokeBtn.innerHTML = '<span class="btn-icon">⚠️</span> Revoke Approval';
          actionBar.appendChild(revokeBtn);
          hasActions = true;
        }
        
        if (actionContainer) {
          actionContainer.style.display = hasActions ? 'block' : 'none';
          actionContainer.style.width = '100%';
        }
      } catch (error) {
        console.error('Error setting up user actions:', error);
      }
    }
    
    function setupRequestButton(thesis, userRole, isAuthor, canRequest, existingRequest) {
      const area = document.getElementById('requestFileArea');
      if (!area) return;

      if (!userRole) {
        // Not logged in — keep the fallback login link
        return;
      }

      if (thesis.status !== 'Approved') {
        area.innerHTML = '<p class="muted text-sm text-center">File requests are only available for approved theses.</p>';
        return;
      }

      if (isAuthor) {
        area.innerHTML = '<p class="muted text-sm text-center">You are the uploader of this thesis.</p>';
        return;
      }

      if (existingRequest) {
        if (existingRequest.status === 'pending') {
          area.innerHTML = `<div style="background:#fff3cd;border:1px solid #ffc107;color:#856404;padding:12px;border-radius:6px;text-align:center">
            ⏳ <strong>Request Pending</strong><br><small>Submitted on ${new Date(existingRequest.createdAt).toLocaleDateString()}. Awaiting approval.</small>
          </div>`;
        } else if (existingRequest.status === 'fulfilled') {
          area.innerHTML = `<div style="background:#d4edda;border:1px solid #c3e6cb;color:#155724;padding:12px;border-radius:6px;text-align:center">
            ✅ <strong>Request Approved</strong><br><small>Check your email for the download link.</small>
          </div>`;
        }
        return;
      }

      // Eligible to request
      area.innerHTML = `
        <button onclick="showRequestModal('${thesis._id}', document.getElementById('title').textContent)" class="btn lg primary" style="margin:0 auto;">
          <span class="btn-icon">&#x1F4EC;</span> Request Thesis via Email
        </button>
        <p class="muted text-sm text-center" style="margin-top:8px">The author and admin will be notified to approve your request.</p>
      `;
    }
    
    function showError(message) {
      document.getElementById('content').innerHTML = `
         <div class="card center flex-col gap-20 min-height-40vh">
          <h2 class="text-danger">Error</h2>
          <p class="muted">${message}</p>
          <a href="/thesis" class="btn">Back to Thesis</a>
        </div>
      `;
    }
    
    function showRejectModal(thesisId, thesisTitle) {
      const modal = document.getElementById('rejectModal');
      const modalTitle = document.getElementById('modalThesisTitle');
      const rejectForm = document.getElementById('rejectForm');
      
      if (modal && modalTitle && rejectForm) {
        modalTitle.textContent = thesisTitle;
        rejectForm.action = `/thesis/${thesisId}/reject`;
        modal.style.display = 'flex';
      }
    }
    
    function hideRejectModal() {
      const modal = document.getElementById('rejectModal');
      if (modal) {
        modal.style.display = 'none';
        const reasonField = document.getElementById('rejectionReason');
        if (reasonField) reasonField.value = '';
      }
    }
    
    function showRevokeModal(thesisId, thesisTitle) {
      const modal = document.getElementById('revokeModal');
      const modalTitle = document.getElementById('revokeModalThesisTitle');
      const revokeForm = document.getElementById('revokeForm');
      
      if (modal && modalTitle && revokeForm) {
        modalTitle.textContent = thesisTitle;
        revokeForm.action = `/thesis/admin/${thesisId}/revoke`;
        modal.style.display = 'flex';
      }
    }
    
    function hideRevokeModal() {
      const modal = document.getElementById('revokeModal');
      if (modal) {
        modal.style.display = 'none';
        const reasonField = document.getElementById('revocationReason');
        if (reasonField) reasonField.value = '';
      }
    }
    
    
     function showRequestModal(thesisId, thesisTitle) {
      document.getElementById('requestThesisId').value = thesisId;
      document.getElementById('requestThesisTitle').textContent = thesisTitle;
      document.getElementById('requestReason').value = '';
      document.getElementById('requestError').style.display = 'none';
      document.getElementById('requestModal').style.display = 'flex';
    }

    function hideRequestModal() {
      document.getElementById('requestModal').style.display = 'none';
    }

    async function submitFileRequest() {
      const thesisId = document.getElementById('requestThesisId').value;
      const reason = document.getElementById('requestReason').value.trim();
      const errorEl = document.getElementById('requestError');
      const submitBtn = document.getElementById('submitRequestBtn');

      if (reason.length < 20) {
        errorEl.textContent = 'Please provide at least 20 characters explaining your reason.';
        errorEl.style.display = 'block';
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitting...';
      errorEl.style.display = 'none';

      try {
        const res = await fetch('/api/thesis-requests', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ thesisId, reason })
        });
        const data = await res.json();
        if (!res.ok) {
          errorEl.textContent = data.error || 'Failed to submit request.';
          errorEl.style.display = 'block';
          submitBtn.disabled = false;
          submitBtn.textContent = '📬 Submit Request';
          return;
        }
        hideRequestModal();
        const area = document.getElementById('requestFileArea');
        if (area) area.innerHTML = `<div style="background:#d4edda;border:1px solid #c3e6cb;color:#155724;padding:12px;border-radius:6px;text-align:center">
          ✅ <strong>Request Submitted!</strong><br><small>${data.message || 'You will be notified by email when approved.'}</small>
        </div>`;
      } catch (err) {
        errorEl.textContent = 'Network error. Please try again.';
        errorEl.style.display = 'block';
        submitBtn.disabled = false;
        submitBtn.textContent = '📬 Submit Request';
      }
    }

    window.onload = load;
  </script>
  
  <!-- Request File Modal -->
  <div id="requestModal" class="modal-overlay" style="display:none">
    <div class="card modal-content-large">
      <h3>📬 Request Thesis File</h3>
      <p>Request the full PDF of <strong id="requestThesisTitle"></strong> to be delivered to your email.</p>
      <input type="hidden" id="requestThesisId">
      <div class="form-group">
        <label for="requestReason">Reason for Request <span style="color:#dc3545">*</span></label>
        <textarea
          id="requestReason"
          placeholder="Please explain why you need access to this thesis (e.g., academic research, related study, professional use)..."
          rows="5"
          minlength="20"
        ></textarea>
        <small class="muted">Minimum 20 characters. Your justification will be sent to the author and administrator for review.</small>
      </div>
      <div id="requestError" class="error-box" style="display:none;margin-top:8px"></div>
      <div class="flex-wrap gap-12 margin-top-20">
        <button type="button" id="submitRequestBtn" class="btn primary" onclick="submitFileRequest()">📬 Submit Request</button>
        <button type="button" class="btn ghost" onclick="hideRequestModal()">Cancel</button>
      </div>
    </div>
  </div>

  <!-- Rejection Modal -->
  <div id="rejectModal" class="modal-overlay">
    <div class="card modal-content-large">
      <h3>❌ Reject Thesis</h3>
      <p><strong>Thesis:</strong> <span id="modalThesisTitle"></span></p>
      <form id="rejectForm" method="POST">
        <div class="form-group">
          <label for="rejectionReason">Reason for Rejection (Optional)</label>
          <textarea 
            id="rejectionReason" 
            name="reason" 
            placeholder="Provide feedback to help the author improve their submission..."
            rows="4"
          ></textarea>
        </div>
        <div class="flex-wrap gap-12 margin-top-20">
          <button type="submit" class="btn danger">❌ Reject Thesis</button>
          <button type="button" class="btn ghost" onclick="hideRejectModal()">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Revoke Approval Modal -->
  <div id="revokeModal" class="modal-overlay">
    <div class="card modal-content-large">
      <h3>⚠️ Revoke Approval</h3>
      <p><strong>Thesis:</strong> <span id="revokeModalThesisTitle"></span></p>
      <div class="warning-box">
        <p><strong>⚠️ Warning:</strong> This will move the thesis back to pending status and remove it from public view. The author will be notified of this change.</p>
      </div>
      <form id="revokeForm" method="POST">
        <div class="form-group">
          <label for="revocationReason">Reason for Revocation (Optional)</label>
          <textarea 
            id="revocationReason" 
            name="reason" 
            placeholder="Explain why approval is being revoked..."
            rows="3"
          ></textarea>
        </div>
        <div class="flex-wrap gap-12 margin-top-20">
          <button type="submit" class="btn warning">⚠️ Revoke Approval</button>
          <button type="button" class="btn ghost" onclick="hideRevokeModal()">Cancel</button>
        </div>
      </form>
    </div>
  </div>
</body>
</html>
