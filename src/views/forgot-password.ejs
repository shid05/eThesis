<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("partials/head") %>
  <title>Forgot Password - LNC Research Archives</title>
  <script src="/public/js/notifications.js"></script>
</head>
<body>
  <div class="bg-bokeh"></div>
  <%- include('partials/navbar') %>
  
  <main class="container">
    <div class="card medium-form">
      <h2>🔑 Forgot Password</h2>
      <p class="muted">Enter your details below and we'll send your request for review. If your account is found, an administrator will process your request.</p>
      
      <!-- Success message (hidden by default) -->
      <div id="successMessage" style="display:none; padding:16px 20px; border-radius:12px; background:rgba(16,185,129,0.1); border:1px solid rgba(16,185,129,0.3); color:var(--success-light); font-size:0.95rem; text-align:center; line-height:1.6;">
        <div style="font-size:1.5rem; margin-bottom:8px;">✅</div>
        <strong>Request Submitted Successfully</strong><br>
        If an account matching your details exists, your request has been sent for admin review. You will receive an email with further instructions once processed.
      </div>
      
      <form id="forgotPasswordForm" class="form-card" onsubmit="return handleForgotPassword(event)" style="display:block;">
        <!-- Inline error banner (hidden by default) -->
        <div id="forgotError" style="display:none; padding:12px 16px; border-radius:12px; background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.3); color:var(--danger-light); font-size:0.9rem; text-align:center;"></div>
        

        
        <div class="form-group">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" required placeholder="you@example.com" />
        </div>
        
        <button type="submit" id="forgotBtn" class="btn lg full-width-btn">
          Submit Request
        </button>
      </form>
      
      <div class="form-divider">
        <p class="muted">Remember your password? <a href="/login">Back to Login</a></p>
      </div>
    </div>
  </main>
  
  <%- include('partials/footer') %>
  
  <script nonce="<%= nonce %>">
    async function handleForgotPassword(e) {
      e.preventDefault();
      
      const email = document.getElementById('email').value.trim();
      const errorBox = document.getElementById('forgotError');
      const successBox = document.getElementById('successMessage');
      const forgotBtn = document.getElementById('forgotBtn');
      const form = document.getElementById('forgotPasswordForm');
      
      // Clear previous errors
      errorBox.style.display = 'none';
      
      // Client-side validation
      let hasErrors = false;
      

      
      if (!email) {
        errorBox.textContent = '⚠️ Email is required.';
        errorBox.style.display = 'block';
        hasErrors = true;
      } else if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        errorBox.textContent = '⚠️ Please enter a valid email address.';
        errorBox.style.display = 'block';
        hasErrors = true;
      }
      
      if (hasErrors) return false;
      
      // Disable button during request
      forgotBtn.disabled = true;
      forgotBtn.textContent = 'Submitting...';
      
      try {
        const res = await fetch('/forgot-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email })
        });
        
        const data = await res.json();
        
        // Always show success (don't reveal if email exists)
        form.style.display = 'none';
        successBox.style.display = 'block';
        
      } catch (err) {
        errorBox.textContent = '⚠️ Network error. Please try again.';
        errorBox.style.display = 'block';
      } finally {
        forgotBtn.disabled = false;
        forgotBtn.textContent = 'Submit Request';
      }
      
      return false;
    }
  </script>
  

</body>
</html>
