<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("partials/head") %>
  <title>LNC Research Archives - Academic Thesis Repository</title>
  <script src="/socket.io/socket.io.js"></script>
  <script src="/public/js/notifications.js"></script>
</head>
<body>
  <div class="bg-bokeh"></div>
  <%- include('partials/navbar') %>
  
  <main class="container">
    <!-- Hero Section -->
    <div class="hero-section">
      <div class="hero-center">
        <div class="hero-logo-row">
          <img src="/public/images/lncfavicon.png" alt="LNC Logo" class="hero-logo" onerror="this.style.display='none'">
          <span class="hero-brand-tag">LNC Research Archives</span>
        </div>
        <h1 class="hero-title">Your Institutional Research Repository</h1>
        <p class="hero-subtitle">Preserving and providing controlled access to approved academic thesis from Laguna Northwestern College.</p>
        <div class="hero-cta">
          <a href="/thesis" class="btn primary hero-btn-primary">Browse Theses</a>
          <a href="/about" class="btn outline hero-btn-outline">Learn More</a>
        </div>
        <% if (typeof currentUser !== 'undefined' && currentUser) { %>
        <p class="hero-greeting">Welcome back, <strong id="userSpan"><%= currentUser.name %></strong></p>
        <% } %>
      </div>
      <div class="hero-features">
        <div class="hero-feature">
          <div class="hero-feature-icon">&#x1F4C4;</div>
          <span class="hero-feature-label">Approved Theses</span>
        </div>
        <div class="hero-feature">
          <div class="hero-feature-icon">&#x1F50E;</div>
          <span class="hero-feature-label">Advanced Search</span>
        </div>
        <div class="hero-feature">
          <div class="hero-feature-icon">&#x2709;&#xFE0F;</div>
          <span class="hero-feature-label">Request Access</span>
        </div>
      </div>
    </div>
    
    <!-- Features Section -->
    <div class="grid">
      <div class="card feature-card">
        <div class="feature-icon">&#x1F50D;</div>
        <h3>Discover Research</h3>
        <p class="muted">Browse through our curated collection of approved academic thesis from various disciplines.</p>
      </div>
      
      <div class="card feature-card">
        <div class="feature-icon">&#x2709;&#xFE0F;</div>
        <h3>Request Thesis File</h3>
        <p class="muted">Submit a justified request to receive a thesis PDF directly to your email after review and approval.</p>
      </div>
      
      <div class="card feature-card">
        <div class="feature-icon">&#x1F393;</div>
        <h3>Academic Excellence</h3>
        <p class="muted">Connect with researchers, share knowledge, and contribute to the academic community.</p>
      </div>
    </div>
    

  </main>
  
  <%- include('partials/footer') %>
  
  <script>
    async function load(){
      try {
        const res = await fetch('/session-info');
        const data = await res.json();
        if (data.user) {
          document.getElementById('userSpan').textContent = data.user.name;
          if (typeof window.setCurrentUser === 'function') {
            window.setCurrentUser(data.user);
          }
        }
      } catch (error) {
        console.error('Error loading homepage data:', error);
      }
    }
    

    

    window.onload = load;
  </script>
</body>
</html>
