<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("partials/head") %>
  <title>Admin Dashboard - LNC Research Archives</title>
  <script src="/socket.io/socket.io.js"></script>
  <script src="/public/js/notifications.js"></script>
</head>
<body>
  <div class="bg-bokeh"></div>
  <%- include('partials/navbar') %>
  
  <main class="container">
    <!-- Dashboard Header -->
    <div class="dashboard-header">
      <div class="dashboard-hero">
        <div class="hero-content">
          <h1 class="dashboard-title">📊 Admin Dashboard</h1>
          <p class="dashboard-subtitle">Monitor and manage the eThesis platform. View statistics, recent activity, and system health.</p>
        </div>
        <div class="dashboard-actions">
          <div class="quick-stats">
            <div class="quick-stat">
              <span class="stat-value" id="quickTotal">0</span>
              <span class="stat-label">Total</span>
            </div>
            <div class="quick-stat">
              <span class="stat-value" id="quickPending">0</span>
              <span class="stat-label">Pending</span>
            </div>
            <div class="quick-stat">
              <span class="stat-value" id="quickRequests">0</span>
              <span class="stat-label">Requests</span>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Statistics Grid -->
    <div class="card stats-overview">
      <div class="section-header">
        <h2>📈 Platform Statistics</h2>
        <p class="section-subtitle">Real-time overview of platform metrics</p>
      </div>
      <div class="stats-grid enhanced">
        <div class="stat-card primary">
          <div class="stat-icon">📄</div>
          <div class="stat-content">
            <h3 class="stat-value" id="totalTheses">Loading...</h3>
            <p class="stat-label">Total Thesis</p>
          </div>
        </div>
        <div class="stat-card warning">
          <div class="stat-icon">⏳</div>
          <div class="stat-content">
            <h3 class="stat-value" id="pendingTheses">Loading...</h3>
            <p class="stat-label">Pending Approval</p>
          </div>
        </div>
        <div class="stat-card success">
          <div class="stat-icon">✅</div>
          <div class="stat-content">
            <h3 class="stat-value" id="approvedTheses">Loading...</h3>
            <p class="stat-label">Approved</p>
          </div>
        </div>
        <div class="stat-card danger">
          <div class="stat-icon">❌</div>
          <div class="stat-content">
            <h3 class="stat-value" id="rejectedTheses">Loading...</h3>
            <p class="stat-label">Rejected</p>
          </div>
        </div>
        <div class="stat-card info">
          <div class="stat-icon">⭐</div>
          <div class="stat-content">
            <h3 class="stat-value" id="totalReviews">Loading...</h3>
            <p class="stat-label">Total Reviews</p>
          </div>
        </div>
        <div class="stat-card secondary">
          <div class="stat-icon">👥</div>
          <div class="stat-content">
            <h3 class="stat-value" id="totalUsers">Loading...</h3>
            <p class="stat-label">Total Users</p>
          </div>
        </div>
        <div class="stat-card accent">
          <div class="stat-icon">👤</div>
          <div class="stat-content">
            <h3 class="stat-value" id="totalRequests">Loading...</h3>
            <p class="stat-label">Account Requests</p>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Quick Actions -->
    <div class="card">
      <h3>Quick Actions</h3>
      <div class="action-bar">
        <a href="/thesis/admin/pending" class="btn warning">⏳ Review Pending Thesis</a>
        <a href="/admin/account-requests" class="btn info">📧 Account Requests</a>
        <a href="/admin/users" class="btn secondary">👥 Manage Users</a>
        <a href="/admin/reports" class="btn outline">📊 Generate Reports</a>
      </div>
    </div>
    
    <!-- Recently Approved Thesis -->
    <div class="card">
      <h3>📄 Recently Approved Thesis</h3>
      <div id="recentlyApproved" class="thesis-grid">
        <div class="text-muted center" style="grid-column: 1 / -1;">Loading...</div>
      </div>
    </div>
    
    <!-- Recent Reviews -->
    <div class="card">
      <h3>⭐ Recent Reviews</h3>
      <div id="recentReviews" class="thesis-grid">
        <div class="text-muted center" style="grid-column: 1 / -1;">Loading...</div>
      </div>
    </div>
  </main>
  
  <%- include('partials/footer') %>
  
  <!-- Rejection Modal -->
  <div id="rejectModal" class="modal-overlay">
    <div class="card modal-content-large">
      <h3>❌ Reject Thesis</h3>
      <p><strong>Thesis:</strong> <span id="modalThesisTitle"></span></p>
      <form id="rejectForm" method="POST">
        <div class="form-group">
          <label for="rejectionReason">Reason for Rejection (Optional)</label>
          <textarea 
            id="rejectionReason" 
            name="reason" 
            placeholder="Provide feedback to help the author improve their submission..."
            rows="4"
          ></textarea>
        </div>
        <div class="flex-wrap gap-12 margin-top-20">
          <button type="submit" class="btn danger">❌ Reject Thesis</button>
          <button type="button" class="btn ghost" onclick="hideRejectModal()">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Revoke Approval Modal -->
  <div id="revokeModal" class="modal-overlay">
    <div class="card modal-content-large">
      <h3>⚠️ Revoke Approval</h3>
      <p><strong>Thesis:</strong> <span id="revokeModalThesisTitle"></span></p>
      <div class="warning-box">
        <p><strong>⚠️ Warning:</strong> This will move the thesis back to pending status and remove it from public view. The author will be notified of this change.</p>
      </div>
      <form id="revokeForm" method="POST">
        <div class="form-group">
          <label for="revocationReason">Reason for Revocation (Optional)</label>
          <textarea 
            id="revocationReason" 
            name="reason" 
            placeholder="Explain why approval is being revoked..."
            rows="3"
          ></textarea>
        </div>
        <div class="flex-wrap gap-12 margin-top-20">
          <button type="submit" class="btn warning">⚠️ Revoke Approval</button>
          <button type="button" class="btn ghost" onclick="hideRevokeModal()">Cancel</button>
        </div>
      </form>
    </div>
  </div>
  
  <script>
    async function onLoad() {
      try {
        const userResponse = await fetch('/session-info');
        const userData = await userResponse.json();
        
        if (!userData.user || userData.user.role !== 'Admin') {
          window.location.href = '/';
          return;
        }
        
        // Set current user for real-time features
        setCurrentUser(userData.user);
        
        // Load dashboard data
        await loadDashboardData();
        
        // Load recent activity
        await loadRecentActivity();
        
        // Auto-refresh every 30 seconds
        setInterval(loadDashboardData, 30000);
        
      } catch (error) {
        console.error('Error loading admin dashboard:', error);
        showNotification('Error loading dashboard data', 'error');
      }
    }
    
    async function loadDashboardData() {
      try {
        const response = await fetch('/api/dashboard-stats');
        const stats = await response.json();
        
        // Update statistics cards
        document.getElementById('totalTheses').textContent = stats.totalTheses || '0';
        document.getElementById('pendingTheses').textContent = stats.pendingTheses || '0';
        document.getElementById('approvedTheses').textContent = stats.approvedTheses || '0';
        document.getElementById('rejectedTheses').textContent = stats.rejectedTheses || '0';
        document.getElementById('totalReviews').textContent = stats.totalReviews || '0';
        document.getElementById('totalUsers').textContent = stats.totalUsers || '0';
        document.getElementById('totalRequests').textContent = stats.totalRequests || '0';
        
        // Update quick stats
        document.getElementById('quickTotal').textContent = stats.totalTheses || '0';
        document.getElementById('quickPending').textContent = stats.pendingTheses || '0';
        document.getElementById('quickRequests').textContent = stats.totalRequests || '0';
        
      } catch (error) {
        console.error('Error loading dashboard data:', error);
      }
    }
    
    async function loadRecentActivity() {
      try {
        // Load recently approved theses
        const approvedRes = await fetch('/api/thesis/recent-approved');
        const approvedData = await approvedRes.json();
        const approvedContainer = document.getElementById('recentlyApproved');
        if (approvedContainer && approvedData.length > 0) {
          const top10 = approvedData.slice(0, 10);
          approvedContainer.innerHTML = top10.map(thesis => `
            <a href="/thesis/${thesis._id}" class="card compact-card" style="text-decoration: none; color: inherit;">
              <h4 class="text-ellipsis" style="margin-bottom: 8px;" title="${thesis.title}">📄 ${thesis.title}</h4>
              <p class="muted text-ellipsis" style="margin-bottom: 8px;">by ${thesis.author?.name || 'Unknown'}</p>
              <p class="text-sm text-muted" style="margin-bottom: 0; margin-top: auto;">${new Date(thesis.createdAt).toLocaleDateString()}</p>
            </a>
          `).join('');
          
          if (approvedData.length > 10) {
             const moreBtn = document.createElement('div');
             moreBtn.style.cssText = 'grid-column: 1 / -1; text-align: center; margin-top: 8px;';
             moreBtn.innerHTML = '<a href="/thesis" class="btn outline">View More Approved Thesis</a>';
             approvedContainer.appendChild(moreBtn);
          }
        } else if (approvedContainer) {
          approvedContainer.innerHTML = '<div class="text-muted center" style="grid-column: 1 / -1;">No recently approved thesis</div>';
        }
        
        
        // Load recent reviews
        const reviewsRes = await fetch('/api/reviews/recent');
        const reviewsData = await reviewsRes.json();
        const reviewsContainer = document.getElementById('recentReviews');
        if (reviewsContainer && reviewsData.length > 0) {
          const top10 = reviewsData.slice(0, 10);
          reviewsContainer.innerHTML = top10.map(review => `
            <a href="/thesis/${review.thesisId?._id || ''}" class="card compact-card" style="text-decoration: none; color: inherit;">
              <h4 class="text-ellipsis" style="margin-bottom: 8px;" title="${review.thesisId?.title || 'Unknown Thesis'}">⭐ ${review.thesisId?.title || 'Unknown Thesis'}</h4>
              <p class="muted text-ellipsis" style="margin-bottom: 4px;">by ${review.reviewerId?.name || 'Unknown'}</p>
              <p class="text-sm text-muted" style="margin-bottom: 4px;">Rating: ${review.rating}/5</p>
              <p class="text-sm text-muted" style="margin-bottom: 0; margin-top: auto;">${new Date(review.createdAt).toLocaleDateString()}</p>
            </a>
          `).join('');
        } else if (reviewsContainer) {
          reviewsContainer.innerHTML = '<div class="text-muted center" style="grid-column: 1 / -1;">No recent reviews</div>';
        }
        
        
      } catch (error) {
        console.error('Error loading recent activity:', error);
      }
    }
    
    function showRejectModal(thesisId, thesisTitle) {
      const modal = document.getElementById('rejectModal');
      const modalTitle = document.getElementById('modalThesisTitle');
      const rejectForm = document.getElementById('rejectForm');
      
      if (modal && modalTitle && rejectForm) {
        modalTitle.textContent = thesisTitle;
        rejectForm.action = `/thesis/admin/${thesisId}/reject`;
        modal.style.display = 'flex';
      }
    }
    
    function hideRejectModal() {
      const modal = document.getElementById('rejectModal');
      if (modal) {
        modal.style.display = 'none';
        const reasonField = document.getElementById('rejectionReason');
        if (reasonField) reasonField.value = '';
      }
    }
    
    function showRevokeModal(thesisId, thesisTitle) {
      const modal = document.getElementById('revokeModal');
      const modalTitle = document.getElementById('revokeModalThesisTitle');
      const revokeForm = document.getElementById('revokeForm');
      
      if (modal && modalTitle && revokeForm) {
        modalTitle.textContent = thesisTitle;
        revokeForm.action = `/thesis/admin/${thesisId}/revoke`;
        modal.style.display = 'flex';
      }
    }
    
    function hideRevokeModal() {
      const modal = document.getElementById('revokeModal');
      if (modal) {
        modal.style.display = 'none';
        const reasonField = document.getElementById('revocationReason');
        if (reasonField) reasonField.value = '';
      }
    }
    
    window.onload = onLoad;
  </script>
</body>
</html>
