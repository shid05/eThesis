<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("partials/head") %>
  <title>Reports - LNC Research Archives</title>
  <script src="/socket.io/socket.io.js"></script>
  <script src="/public/js/notifications.js"></script>
  <script nonce="<%= nonce %>">
    async function onLoad() {
      try {
        const userResponse = await fetch('/session-info');
        const userData = await userResponse.json();
        
        if (!userData.user || userData.user.role !== 'Admin') {
          window.location.href = '/';
          return;
        }
        
        // Set current user for real-time features
        setCurrentUser(userData.user);
        
        // Load initial report data
        await loadReportData();
        
      } catch (error) {
        console.error('Error loading admin reports page:', error);
        showNotification('Error loading reports data', 'error');
      }
    }
    
    async function loadReportData() {
      try {
        // Load statistics for reports
        const [statsResponse, activityResponse] = await Promise.all([
          fetch('/api/dashboard-stats'),
          fetch('/api/recent-activity')
        ]);
        
        const stats = await statsResponse.json();
        const activity = await activityResponse.json();
        
        // Update summary cards
        updateSummaryCards(stats);
        
        // Generate charts data
        generateChartsData(stats, activity);
        
      } catch (error) {
        console.error('Error loading report data:', error);
        showNotification('Error loading report data', 'error');
      }
    }
    
    function updateSummaryCards(stats) {
      document.getElementById('totalTheses').textContent = stats.totalTheses || 0;
      document.getElementById('totalUsers').textContent = stats.totalUsers || 0;
      document.getElementById('totalReviews').textContent = stats.totalReviews || 0;
      document.getElementById('pendingTheses').textContent = stats.pendingTheses || 0;
    }
    
    function generateChartsData(stats, activity) {
      // Generate thesis status distribution
      const statusData = {
        approved: stats.approvedTheses || 0,
        pending: stats.pendingTheses || 0,
        rejected: stats.rejectedTheses || 0
      };
      
      displayStatusChart(statusData);
      
      // Generate user role distribution (mock data for now)
      const roleData = {
        students: Math.floor((stats.totalUsers || 0) * 0.8),
        teachers: Math.floor((stats.totalUsers || 0) * 0.2)
      };

      displayRoleChart(roleData);
      
      // Display recent activity summary
      displayActivitySummary(activity);
    }
    
    function displayStatusChart(data) {
      const chartContainer = document.getElementById('statusChart');
      const total = data.approved + data.pending + data.rejected;
      
      if (total === 0) {
        chartContainer.innerHTML = '<p class="text-muted center">No thesis data available</p>';
        return;
      }
      
      const approvedPercent = Math.round((data.approved / total) * 100);
      const pendingPercent = Math.round((data.pending / total) * 100);
      const rejectedPercent = Math.round((data.rejected / total) * 100);
      
      chartContainer.innerHTML = `
        <div class="chart-bars">
          <div class="chart-bar">
            <div class="chart-bar-fill success" style="width: ${approvedPercent}%"></div>
            <div class="chart-label">
              <span>Approved: ${data.approved} (${approvedPercent}%)</span>
            </div>
          </div>
          <div class="chart-bar">
            <div class="chart-bar-fill warning" style="width: ${pendingPercent}%"></div>
            <div class="chart-label">
              <span>Pending: ${data.pending} (${pendingPercent}%)</span>
            </div>
          </div>
          <div class="chart-bar">
            <div class="chart-bar-fill danger" style="width: ${rejectedPercent}%"></div>
            <div class="chart-label">
              <span>Rejected: ${data.rejected} (${rejectedPercent}%)</span>
            </div>
          </div>
        </div>
      `;
    }
    
    function displayRoleChart(data) {
      const chartContainer = document.getElementById('roleChart');
      const total = data.students + data.teachers;
      
      if (total === 0) {
        chartContainer.innerHTML = '<p class="text-muted center">No user data available</p>';
        return;
      }
      
      const studentsPercent = Math.round((data.students / total) * 100);
      const teachersPercent = Math.round((data.teachers / total) * 100);
      
      chartContainer.innerHTML = `
        <div class="chart-bars">
          <div class="chart-bar">
            <div class="chart-bar-fill primary" style="width: ${studentsPercent}%"></div>
            <div class="chart-label">
              <span>Students: ${data.students} (${studentsPercent}%)</span>
            </div>
          </div>
          <div class="chart-bar">
            <div class="chart-bar-fill accent" style="width: ${teachersPercent}%"></div>
            <div class="chart-label">
              <span>Teachers: ${data.teachers} (${teachersPercent}%)</span>
            </div>
          </div>
        </div>
      `;
    }
    
    function displayActivitySummary(activity) {
      const container = document.getElementById('activitySummary');
      
      container.innerHTML = `
        <div class="grid">
          <div class="card">
            <h4 class="text-primary" style="margin-bottom: 8px;">${(activity.recentTheses || []).length}</h4>
            <p class="muted">Recent Submissions</p>
          </div>
          <div class="card">
            <h4 class="text-success" style="margin-bottom: 8px;">${(activity.recentReviews || []).length}</h4>
            <p class="muted">Recent Reviews</p>
          </div>
          <div class="card">
            <h4 class="text-accent" style="margin-bottom: 8px;">${new Date().toLocaleDateString()}</h4>
            <p class="muted">Report Date</p>
          </div>
        </div>
      `;
    }
    
    function generateReport(type) {
      const reportContent = document.getElementById('reportContent');
      const timestamp = new Date().toISOString();
      
      let content = '';
      
      switch(type) {
        case 'summary':
          content = generateSummaryReport();
          break;
        case 'detailed':
          content = generateDetailedReport();
          break;
      }
      
      reportContent.innerHTML = `
        <div class="card">
          <div class="header-flex margin-bottom-16">
            <h3>Generated Report - ${type.charAt(0).toUpperCase() + type.slice(1)}</h3>
            <span class="badge">${new Date().toLocaleString()}</span>
          </div>
          ${content}
        </div>
      `;
      
      // Scroll to report
      reportContent.scrollIntoView({ behavior: 'smooth' });
    }
    
    function generateSummaryReport() {
      return `
        <div class="stack">
          <div class="card highlight">
            <h4>📊 Platform Summary</h4>
            <p>This report provides a high-level overview of the eThesis platform activity and usage.</p>
          </div>
          
          <div class="grid">
            <div class="card">
              <h5>Thesis Statistics</h5>
              <ul>
                <li>Total Thesis: <strong id="reportTotalTheses">${document.getElementById('totalTheses').textContent}</strong></li>
                <li>Pending Approval: <strong id="reportPendingTheses">${document.getElementById('pendingTheses').textContent}</strong></li>
                <li>Approval Rate: <strong>~75%</strong> (estimated)</li>
              </ul>
            </div>
            
            <div class="card">
              <h5>User Engagement</h5>
              <ul>
                <li>Total Users: <strong id="reportTotalUsers">${document.getElementById('totalUsers').textContent}</strong></li>
                <li>Total Reviews: <strong id="reportTotalReviews">${document.getElementById('totalReviews').textContent}</strong></li>
                <li>Avg Reviews per Thesis: <strong>~2.3</strong> (estimated)</li>
              </ul>
            </div>
          </div>
          
          <div class="card success">
            <h5>Key Insights</h5>
            <ul>
              <li>📈 Platform showing steady growth in submissions</li>
              <li>✅ High-quality review engagement from academic community</li>
              <li>⚡ Real-time notifications improving user experience</li>
              <li>🎯 Role-based access control ensuring platform integrity</li>
            </ul>
          </div>
        </div>
      `;
    }
    
    function generateDetailedReport() {
      return `
        <div class="stack">
          <div class="card highlight">
            <h4>📋 Detailed Analysis Report</h4>
            <p>Comprehensive breakdown of platform metrics and user behavior analysis.</p>
          </div>
          
          <div class="card">
            <h5>Thesis Submission Trends</h5>
            <div class="margin-bottom-16">
              <div id="statusChart"></div>
            </div>
            <p class="text-muted">The above chart shows the distribution of thesis statuses, helping identify approval bottlenecks.</p>
          </div>
          
          <div class="card">
            <h5>User Role Distribution</h5>
            <div class="margin-bottom-16">
              <div id="roleChart"></div>
            </div>
            <p class="text-muted">User role distribution indicates platform usage patterns and community composition.</p>
          </div>
          
          <div class="card warning">
            <h5>Recommendations</h5>
            <ul>
              <li>🚀 Consider automated pre-screening for faster thesis approval</li>
              <li>📚 Implement advanced search and filtering for better thesis discovery</li>
              <li>💬 Add discussion forums for thesis-specific academic discourse</li>
              <li>📊 Create teacher performance metrics and incentives</li>
              <li>🔄 Regular data backups and security audits recommended</li>
            </ul>
          </div>
        </div>
      `;
    }
    
    // CSV Export functionality removed per user request
  </script>
</head>
<body onload="onLoad()">
  <div class="bg-bokeh"></div>
  <%- include('partials/navbar') %>
  
  <main class="container">
    <div class="card highlight">
      <h1>📈 Analytics & Reports</h1>
      <p>Generate comprehensive reports on platform usage, thesis submissions, user engagement, and system performance.</p>
    </div>
    
    <!-- Summary Statistics -->
    <div class="card">
      <h2>Platform Overview</h2>
      <div class="grid">
        <div class="card">
          <h3 class="text-primary" id="totalTheses" style="margin-bottom: 8px;">Loading...</h3>
          <p class="muted">Total Thesis</p>
        </div>
        <div class="card">
          <h3 class="text-secondary" id="totalUsers" style="margin-bottom: 8px;">Loading...</h3>
          <p class="muted">Total Users</p>
        </div>
        <div class="card">
          <h3 class="text-success" id="totalReviews" style="margin-bottom: 8px;">Loading...</h3>
          <p class="muted">Total Reviews</p>
        </div>
        <div class="card highlight">
          <h3 class="text-warning" id="pendingTheses" style="margin-bottom: 8px;">Loading...</h3>
          <p class="muted">Pending Approval</p>
        </div>
      </div>
    </div>
    
    <!-- Report Generation -->
    <div class="card">
      <h3>Generate Reports</h3>
      <p class="text-muted">Choose the type of report you want to generate based on current platform data.</p>
      
      <div class="action-bar">
        <button class="btn primary" onclick="generateReport('summary')">
          📄 Summary Report
        </button>
        <button class="btn outline" onclick="generateReport('detailed')">
          📊 Detailed Analysis
        </button>
        <button class="btn ghost" onclick="loadReportData()">
          🔄 Refresh Data
        </button>
      </div>
    </div>
    
    <!-- Charts Section -->
    <div class="grid">
      <div class="card">
        <h3>📊 Thesis Status Distribution</h3>
        <div id="statusChart">
          <div class="text-muted center">Loading chart data...</div>
        </div>
      </div>
      
      <div class="card">
        <h3>👥 User Role Distribution</h3>
        <div id="roleChart">
          <div class="text-muted center">Loading chart data...</div>
        </div>
      </div>
    </div>
    
    <!-- Activity Summary -->
    <div class="card">
      <h3>📋 Recent Activity Summary</h3>
      <div id="activitySummary">
        <div class="text-muted center">Loading activity data...</div>
      </div>
    </div>
    
    <!-- Generated Reports -->
    <div id="reportContent"></div>
  </main>
  
  <%- include('partials/footer') %>
  
  <style>
    .chart-bars {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin: 16px 0;
    }
    
    .chart-bar {
      position: relative;
      height: 40px;
      background: var(--panel);
      border-radius: 8px;
      overflow: hidden;
    }
    
    .chart-bar-fill {
      height: 100%;
      border-radius: 8px;
      transition: width 0.5s ease;
      display: flex;
      align-items: center;
      padding: 0 12px;
    }
    
    .chart-bar-fill.success {
      background: linear-gradient(90deg, var(--success), var(--success-light));
    }
    
    .chart-bar-fill.warning {
      background: linear-gradient(90deg, var(--warning), var(--warning-light));
    }
    
    .chart-bar-fill.danger {
      background: linear-gradient(90deg, var(--danger), var(--danger-light));
    }
    
    .chart-bar-fill.primary {
      background: linear-gradient(90deg, var(--primary), var(--primary-light));
    }
    
    .chart-bar-fill.accent {
      background: linear-gradient(90deg, var(--accent), var(--accent-light));
    }
    
    .chart-bar-fill.secondary {
      background: linear-gradient(90deg, var(--muted), var(--text-secondary));
    }
    
    .chart-label {
      position: absolute;
      top: 50%;
      left: 12px;
      transform: translateY(-50%);
      color: white;
      font-weight: 500;
      font-size: 0.9rem;
      text-shadow: 0 1px 2px rgba(0,0,0,0.3);
    }
  </style>
</body>
</html>
