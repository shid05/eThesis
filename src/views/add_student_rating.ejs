<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("partials/head") %>
  <title>Rate Thesis - LNC Research Archives</title>
  <script src="/socket.io/socket.io.js"></script>
  <script src="/public/js/notifications.js"></script>
</head>
<body>
  <div class="bg-bokeh"></div>
  <%- include('partials/navbar') %>
  
  <main class="container" id="content">
    <div class="card medium-form">
      <h2>⭐ Rate Thesis</h2>
      <p class="muted">Share your feedback on this thesis.</p>
      
      <form id="ratingForm" method="POST" class="form-card" onsubmit="return validate()">
        <div class="form-group">
          <label for="rating">Rating</label>
          <select id="rating" name="rating" required>
            <option value="">Select a rating</option>
            <option value="1">1 - Poor</option>
            <option value="2">2 - Fair</option>
            <option value="3">3 - Good</option>
            <option value="4">4 - Very Good</option>
            <option value="5">5 - Excellent</option>
          </select>
        </div>
        
        <div class="form-group">
          <label for="comment">Your Review</label>
          <textarea id="comment" name="comment" rows="8" required placeholder="Share your thoughts on this thesis, including what you learned, what was helpful, and overall assessment..."></textarea>
        </div>
        
        <button type="submit" class="btn lg full-width-btn">
          ⭐ Submit Rating
        </button>
      </form>
    </div>
  </main>
  
  <%- include('partials/footer') %>
  
  <script>
    async function loadThesis() {
      // Pull the thesisId out of the page URL (/student-ratings/add/:thesisId)
      // and wire it into the form action so submission hits the matching route.
      const id = location.pathname.split('/').pop();
      const form = document.getElementById('ratingForm');
      if (form) form.action = `/student-ratings/add/${id}`;

      try {
        const res = await fetch(`/thesis/api/${id}`);

        if (!res.ok) {
          const errorData = await res.json().catch(() => ({}));
          const errorMessage = errorData.error || 'Thesis not found';
          document.getElementById('content').innerHTML = `
            <div class="card center flex-col gap-20" style="min-height: 40vh;">
              <h2 class="text-danger">Error</h2>
              <p class="muted">${errorMessage}</p>
              <a href="/thesis" class="btn">Back to Thesis</a>
            </div>
          `;
          return;
        }

        const { thesis } = await res.json();

      } catch (error) {
        document.getElementById('content').innerHTML = `
          <div class="card center flex-col gap-20" style="min-height: 40vh;">
            <h2 class="text-danger">Error</h2>
            <p class="muted">Failed to load thesis: ${error.message}</p>
            <a href="/thesis" class="btn">Back to Thesis</a>
          </div>
        `;
      }
    }
    
    function validate() {
      const rating = document.getElementById('rating').value;
      const comment = document.getElementById('comment').value.trim();
      
      if (!rating) {
        alert('Please select a rating');
        return false;
      }
      
      if (!comment || comment.length < 10) {
        alert('Please provide at least 10 characters of feedback');
        return false;
      }
      
      return true;
    }
    
    window.onload = loadThesis;
  </script>
</body>
</html>
