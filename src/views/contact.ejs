<!DOCTYPE html>
<html lang="en">

<head>
  <%- include("partials/head") %>
    <meta name="description" content="Contact the LNC Research Archives team for support, feedback, or inquiries." />
    <title>Contact - LNC Research Archives</title>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/public/js/notifications.js"></script>
</head>

<body>
  <div class="bg-bokeh"></div>
  <%- include('partials/navbar') %>

    <main class="container">
      <!-- Page Header -->
      <div class="card highlight">
        <h1>📬 Contact Us</h1>
        <p class="hero-subtitle">Have questions, feedback, or need technical support? We're here to help.</p>
      </div>

      <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));">
        <!-- Contact Info -->
        <div class="card">
          <h2>📍 Get in Touch</h2>
          <div class="stack" style="gap: 20px; margin-top: 12px;">

            <div style="display: flex; align-items: flex-start; gap: 16px;">
              <span style="font-size: 1.5rem;">🏫</span>
              <div>
                <strong>Institution</strong>
                <p class="muted" style="margin: 4px 0 0;">Laguna Northwestern College<br />San Lorenzo Ruiz Montessori
                  Center</p>
              </div>
            </div>

            <div style="display: flex; align-items: flex-start; gap: 16px;">
              <span style="font-size: 1.5rem;">👨‍🏫</span>
              <div>
                <strong>Project Adviser</strong>
                <p class="muted" style="margin: 4px 0 0;">Mr. Michael Rojo</p>
              </div>
            </div>

            <div style="display: flex; align-items: flex-start; gap: 16px;">
              <span style="font-size: 1.5rem;">📧</span>
              <div>
                <strong>Email</strong>
                <p class="muted" style="margin: 4px 0 0;">Contact your institution's IT department or reach out to the
                  development team via their social profiles linked in the footer.</p>
              </div>
            </div>

            <div style="display: flex; align-items: flex-start; gap: 16px;">
              <span style="font-size: 1.5rem;">🕐</span>
              <div>
                <strong>Availability</strong>
                <p class="muted" style="margin: 4px 0 0;">Monday – Friday, 8:00 AM – 5:00 PM (PHT)</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Quick Actions -->
        <div class="card">
          <h2>🚀 Quick Actions</h2>
          <div class="stack" style="gap: 16px; margin-top: 12px;">
            <a href="/request-account" class="btn ghost" style="width: 100%; justify-content: flex-start; gap: 12px;">
              👤 Request an Account
            </a>
            <a href="/help" class="btn ghost" style="width: 100%; justify-content: flex-start; gap: 12px;">
              ❓ Visit Help Center
            </a>
            <a href="/thesis" class="btn ghost" style="width: 100%; justify-content: flex-start; gap: 12px;">
              📚 Browse Thesis
            </a>
            <a href="/" class="btn ghost" style="width: 100%; justify-content: flex-start; gap: 12px;">
              🏠 Back to Home
            </a>
          </div>
        </div>
      </div>

      <!-- Development Team -->
      <div class="card" style="text-align: center;">
        <h2>👨‍💻 Development Team</h2>
        <p class="muted" style="margin-bottom: 16px;">Reach the developers directly through their social profiles:</p>
        <div style="display: flex; flex-wrap: wrap; justify-content: center; gap: 12px;">
          <a href="https://www.facebook.com/franzraschid/" target="_blank" class="btn sm ghost">Franz Raschid Loyola</a>
          <a href="https://www.facebook.com/Unknown.user.00.00x" target="_blank" class="btn sm ghost">Hanz Villegas</a>
          <a href="https://www.facebook.com/chrls.drwin" target="_blank" class="btn sm ghost">Charles Darwin Garcia</a>
          <a href="https://www.facebook.com/search/top?q=jeyem%20aquino" target="_blank" class="btn sm ghost">John
            Michael Aquino</a>
          <a href="https://www.facebook.com/aira.francisco.311" target="_blank" class="btn sm ghost">Aira Joy
            Francisco</a>
        </div>
      </div>
    </main>

    <%- include('partials/footer') %>
</body>

</html>