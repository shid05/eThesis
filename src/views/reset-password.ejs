<!DOCTYPE html>
<html lang="en">
<head>
  <%- include("partials/head") %>
  <title>Reset Password - LNC Research Archives</title>
  <script src="/public/js/notifications.js"></script>
</head>
<body>
  <div class="bg-bokeh"></div>
  <%- include('partials/navbar') %>
  
  <main class="container">
    <div class="card medium-form">
      <h2>🔒 Reset Your Password</h2>
      <p class="muted">Enter your new password below. Make sure it's at least 6 characters long.</p>
      
      <!-- Token Error (shown when token is invalid/expired) -->
      <% if (typeof tokenError !== 'undefined' && tokenError) { %>
        <div style="padding:20px; border-radius:12px; background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.3); color:var(--danger-light); text-align:center; line-height:1.6;">
          <div style="font-size:2rem; margin-bottom:12px;">⚠️</div>
          <strong>Invalid or Expired Link</strong><br>
          <p style="margin-top:8px; color:var(--muted);">This password reset link is invalid or has expired. Please submit a new forgot password request.</p>
          <a href="/forgot-password" class="btn ghost sm" style="margin-top:12px;">Request New Link</a>
        </div>
      <% } else { %>
        
        <!-- Success message (hidden by default) -->
        <div id="resetSuccess" style="display:none; padding:20px; border-radius:12px; background:rgba(16,185,129,0.1); border:1px solid rgba(16,185,129,0.3); color:var(--success-light); text-align:center; line-height:1.6;">
          <div style="font-size:2rem; margin-bottom:12px;">✅</div>
          <strong>Password Reset Successfully!</strong><br>
          <p style="margin-top:8px; color:var(--muted);">Your password has been updated. You can now log in with your new password.</p>
          <a href="/login" class="btn lg" style="margin-top:16px; display:inline-flex;">Sign In Now</a>
        </div>
        
        <form id="resetPasswordForm" class="form-card" onsubmit="return handleResetPassword(event)">
          <!-- Inline error banner (hidden by default) -->
          <div id="resetError" style="display:none; padding:12px 16px; border-radius:12px; background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.3); color:var(--danger-light); font-size:0.9rem; text-align:center;"></div>
          
          <input type="hidden" id="resetToken" value="<%= token %>" />
          
          <div class="form-group">
            <label for="newPassword">New Password</label>
            <div class="password-field">
              <input type="password" id="newPassword" name="newPassword" required placeholder="Minimum 6 characters" minlength="6" autocomplete="new-password" />
              <button type="button" class="password-toggle" id="toggleNewPassword" aria-label="Show password" aria-pressed="false">
                <svg class="icon-eye" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z"/>
                  <circle cx="12" cy="12" r="3"/>
                </svg>
                <svg class="icon-eye-off" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M17.94 17.94A10.94 10.94 0 0 1 12 19c-6.5 0-10-7-10-7a18.45 18.45 0 0 1 5.06-5.94"/>
                  <path d="M9.9 4.24A10.94 10.94 0 0 1 12 4c6.5 0 10 7 10 7a18.5 18.5 0 0 1-2.16 3.19"/>
                  <path d="M14.12 14.12a3 3 0 1 1-4.24-4.24"/>
                  <line x1="2" y1="2" x2="22" y2="22"/>
                </svg>
              </button>
            </div>
          </div>
          
          <div class="form-group">
            <label for="confirmPassword">Confirm Password</label>
            <div class="password-field">
              <input type="password" id="confirmPassword" name="confirmPassword" required placeholder="Re-enter your new password" minlength="6" autocomplete="new-password" />
              <button type="button" class="password-toggle" id="toggleConfirmPassword" aria-label="Show password" aria-pressed="false">
                <svg class="icon-eye" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z"/>
                  <circle cx="12" cy="12" r="3"/>
                </svg>
                <svg class="icon-eye-off" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M17.94 17.94A10.94 10.94 0 0 1 12 19c-6.5 0-10-7-10-7a18.45 18.45 0 0 1 5.06-5.94"/>
                  <path d="M9.9 4.24A10.94 10.94 0 0 1 12 4c6.5 0 10 7 10 7a18.5 18.5 0 0 1-2.16 3.19"/>
                  <path d="M14.12 14.12a3 3 0 1 1-4.24-4.24"/>
                  <line x1="2" y1="2" x2="22" y2="22"/>
                </svg>
              </button>
            </div>
          </div>

          <!-- Password strength indicator -->
          <div id="passwordStrength" style="display:none;">
            <div style="height:4px; border-radius:2px; background:var(--border); overflow:hidden; margin-bottom:6px;">
              <div id="strengthBar" style="height:100%; width:0%; border-radius:2px; transition:all 0.3s ease;"></div>
            </div>
            <p id="strengthText" style="font-size:0.8rem; margin:0; color:var(--muted);"></p>
          </div>
          
          <button type="submit" id="resetBtn" class="btn lg full-width-btn">
            Reset Password
          </button>
        </form>
      <% } %>
      
      <div class="form-divider">
        <p class="muted">Remember your password? <a href="/login">Back to Login</a></p>
      </div>
    </div>
  </main>
  
  <%- include('partials/footer') %>
  
  <script nonce="<%= nonce %>">
    // Password toggle functionality
    function setupToggle(toggleId, inputId) {
      const toggle = document.getElementById(toggleId);
      const input = document.getElementById(inputId);
      if (!toggle || !input) return;
      
      toggle.addEventListener('click', function () {
        const isHidden = input.type === 'password';
        input.type = isHidden ? 'text' : 'password';
        toggle.classList.toggle('is-visible', isHidden);
        toggle.setAttribute('aria-pressed', isHidden ? 'true' : 'false');
        toggle.setAttribute('aria-label', isHidden ? 'Hide password' : 'Show password');
        input.focus({ preventScroll: true });
      });
    }
    setupToggle('toggleNewPassword', 'newPassword');
    setupToggle('toggleConfirmPassword', 'confirmPassword');
    
    // Password strength indicator
    const pwInput = document.getElementById('newPassword');
    if (pwInput) {
      pwInput.addEventListener('input', function() {
        const val = pwInput.value;
        const strengthDiv = document.getElementById('passwordStrength');
        const bar = document.getElementById('strengthBar');
        const text = document.getElementById('strengthText');
        
        if (!val) {
          strengthDiv.style.display = 'none';
          return;
        }
        
        strengthDiv.style.display = 'block';
        let score = 0;
        if (val.length >= 6) score++;
        if (val.length >= 10) score++;
        if (/[A-Z]/.test(val)) score++;
        if (/[0-9]/.test(val)) score++;
        if (/[^A-Za-z0-9]/.test(val)) score++;
        
        const levels = [
          { width: '20%', color: '#ef4444', label: 'Very Weak' },
          { width: '40%', color: '#f59e0b', label: 'Weak' },
          { width: '60%', color: '#eab308', label: 'Fair' },
          { width: '80%', color: '#22c55e', label: 'Strong' },
          { width: '100%', color: '#10b981', label: 'Very Strong' }
        ];
        
        const level = levels[Math.min(score, levels.length - 1)];
        bar.style.width = level.width;
        bar.style.background = level.color;
        text.textContent = 'Password strength: ' + level.label;
        text.style.color = level.color;
      });
    }
    
    async function handleResetPassword(e) {
      e.preventDefault();
      
      const token = document.getElementById('resetToken').value;
      const newPassword = document.getElementById('newPassword').value.trim();
      const confirmPassword = document.getElementById('confirmPassword').value.trim();
      const errorBox = document.getElementById('resetError');
      const successBox = document.getElementById('resetSuccess');
      const resetBtn = document.getElementById('resetBtn');
      const form = document.getElementById('resetPasswordForm');
      
      errorBox.style.display = 'none';
      
      // Validation
      if (!newPassword || newPassword.length < 6) {
        errorBox.textContent = '⚠️ Password must be at least 6 characters long.';
        errorBox.style.display = 'block';
        return false;
      }
      
      if (newPassword !== confirmPassword) {
        errorBox.textContent = '⚠️ Passwords do not match.';
        errorBox.style.display = 'block';
        return false;
      }
      
      resetBtn.disabled = true;
      resetBtn.textContent = 'Resetting...';
      
      try {
        const res = await fetch('/reset-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token, newPassword })
        });
        
        const data = await res.json();
        
        if (res.ok) {
          form.style.display = 'none';
          successBox.style.display = 'block';
        } else {
          errorBox.textContent = '⚠️ ' + (data.error || 'Failed to reset password.');
          errorBox.style.display = 'block';
          errorBox.style.animation = 'none';
          errorBox.offsetHeight;
          errorBox.style.animation = 'shake 0.4s ease';
        }
      } catch (err) {
        errorBox.textContent = '⚠️ Network error. Please try again.';
        errorBox.style.display = 'block';
      } finally {
        resetBtn.disabled = false;
        resetBtn.textContent = 'Reset Password';
      }
      
      return false;
    }
  </script>
  
  <style>
    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      20% { transform: translateX(-8px); }
      40% { transform: translateX(8px); }
      60% { transform: translateX(-4px); }
      80% { transform: translateX(4px); }
    }
    
    .password-field {
      position: relative;
      display: flex;
      align-items: center;
    }
    .password-field input {
      padding-right: 48px;
    }
    .password-toggle {
      position: absolute;
      right: 12px;
      background: none;
      border: none;
      color: var(--muted);
      cursor: pointer;
      padding: 4px;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: none;
      min-width: auto;
      min-height: auto;
      width: auto;
      height: auto;
    }
    .password-toggle:hover { color: var(--text); }
    .password-toggle::before { content: none !important; display: none !important; }
    .password-toggle .icon-eye-off { display: none; }
    .password-toggle.is-visible .icon-eye { display: none; }
    .password-toggle.is-visible .icon-eye-off { display: block; }
  </style>
</body>
</html>
